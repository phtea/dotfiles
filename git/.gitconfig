[core]
    preloadIndex = true
    parallelCheckout = true
    excludesfile = /home/phtea/.gitignore

[alias]
    st = status
    lg = log --oneline --graph --decorate --all

[init]
    defaultBranch = main

[include]
    path = ~/.gitconfig_local

[push]
    default = simple

[pull]
    rebase = true

[fetch]
    prune = true

[format]
    pretty = format:%C(auto)%h%d %s %C(blue)%cr %C(black)%an

[merge]
	tool = nvimdiff

[mergetool]
	prompt = false
	keepBackup = false

[mergetool "nvimdiff"]
	layout = LOCAL,BASE,REMOTE / MERGED

[diff]
    tool = nvimdiff

[user]
    email = phtea@mail.com
    name = phtea

[rerere]
    enabled = true
