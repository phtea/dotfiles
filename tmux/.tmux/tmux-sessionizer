#!/usr/bin/env bash
printf '\e[6 q' # Thin cursor

FRECENCY_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/tmux-session-frecency"
mkdir -p "$(dirname "$FRECENCY_FILE")"
touch "$FRECENCY_FILE"

current=""
[[ -n $TMUX ]] && current="$(tmux display-message -p '#S')"

# Show sessions except current, sorted by frecency score desc
selected=$(
  tmux list-sessions -F "#{session_name}" |
    awk -v current="$current" '$0 != current' |
    awk -v file="$FRECENCY_FILE" '
      BEGIN {
        while ((getline < file) > 0)
          score[$1] = $2
      }
      {
        printf "%6d  %s\n", score[$0] + 0, $0
      }
    ' |
    sort -rn |
		fzf \
  --info=hidden \
  --delimiter=' ' \
  --color='bg:#1F1F1F,bg+:#1F1F1F,fg:#888888,fg+:#D4D4D4,prompt:#888888,hl:underline:-1,hl+:underline:-1' \
  --prompt='Session  ' \
  --layout=reverse \
  --pointer=' ' \
  --with-nth=2.. |
    awk '{print $NF}'
)

[[ -z $selected ]] && exit 0

# Update frecency: simple weighted count with time decay-ish bump
now=$(date +%s)
tmp=$(mktemp)

awk -v selected="$selected" -v now="$now" '
  $1 == selected {
    # score = old score + 100, slightly decayed by age in days
    age_days = (now - $3) / 86400
    decay = 0.95 ^ age_days
    $2 = int(($2 * decay) + 100)
    $3 = now
    seen = 1
  }
  { print }
  END {
    if (!seen) print selected, 100, now
  }
' "$FRECENCY_FILE" > "$tmp" && mv "$tmp" "$FRECENCY_FILE"

if [[ -n $TMUX ]]; then
  tmux switch-client -t "$selected"
else
  tmux attach-session -t "$selected"
fi
